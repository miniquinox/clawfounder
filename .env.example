# ===========================================
# ClawFounder — Environment Variables
# ===========================================
# Copy this file to .env and fill in your keys.
# You only need the keys for the provider + connectors you use.

# --- LLM Providers (pick at least one) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Gemini Model Configuration ---
# Model for voice agent (Gemini Live API)
# AI Studio: gemini-2.5-flash-native-audio-preview-12-2025
# Vertex AI: gemini-live-2.5-flash-native-audio
GEMINI_LIVE_MODEL=

# Model for briefing and text generation
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview
GEMINI_MODEL=

# --- Gmail Connector ---
# No env vars needed — uses gcloud Application Default Credentials.
# Run: gcloud auth application-default login --scopes=openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send

# --- Telegram Connector ---
TELEGRAM_BOT_TOKEN=            # From @BotFather
TELEGRAM_CHAT_ID=              # Your chat ID (use @userinfobot to find it)

# --- GitHub Connector ---
GITHUB_TOKEN=                  # Personal access token (Settings → Developer settings → Tokens)

# --- Supabase Connector ---
SUPABASE_URL=                  # Your project URL (e.g., https://xxx.supabase.co)
SUPABASE_SERVICE_KEY=          # Service role key (NOT the anon key)

# --- Firebase Connector ---
FIREBASE_PROJECT_ID=           # Your Firebase project ID
FIREBASE_CREDENTIALS_FILE=     # Path to service account JSON

# --- Yahoo Finance Connector ---
# No API key needed — yfinance is free and open
